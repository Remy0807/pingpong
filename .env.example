# Local API base. App Hosting can use the same-origin default, so this is mostly
# for local development.
VITE_API_BASE_URL=http://localhost:4000
PORT=4000

# Firebase web app config for the client-side Firebase SDK.
# In App Hosting you can set this as one JSON string.
VITE_FIREBASE_WEBAPP_CONFIG={"apiKey":"your-api-key","authDomain":"your-project.firebaseapp.com","projectId":"your-project-id","appId":"your-app-id"}
# Optional extras if your config includes them.
# VITE_FIREBASE_MESSAGING_SENDER_ID=...
# VITE_FIREBASE_STORAGE_BUCKET=...

# Firebase Admin SDK credentials. Use one of these in production.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Local Firestore emulator, optional.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Optional Teams notifications.
# TEAMS_WEBHOOK_URL=
